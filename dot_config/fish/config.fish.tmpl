set -g fish_greeting
fish_config theme choose "Dracula Official"

# Local binaries
fish_add_path ~/.local/bin

# Bun
fish_add_path ~/.bun/bin

# Homebrew
eval (/opt/homebrew/bin/brew shellenv)

# Google Cloud SDK
fish_add_path $HOMEBREW_PREFIX/share/google-cloud-sdk/bin

# OrbStack: command-line tools and integration
source ~/.orbstack/shell/init2.fish 2>/dev/null; or true

# Mise
mise activate fish | source

# fzf: Ctrl+T (files), Ctrl+R (history), Alt+C (cd), Dracula colors
set -gx FZF_DEFAULT_OPTS "--color=fg:#f8f8f2,bg:#282a36,hl:#bd93f9,fg+:#f8f8f2,bg+:#44475a,hl+:#bd93f9,info:#ffb86c,prompt:#50fa7b,pointer:#ff79c6,marker:#ff79c6,spinner:#ffb86c,header:#6272a4"
fzf --fish | source

# Zoxide: smarter cd (z <dir>, zi = interactive)
zoxide init fish | source

# Git worktree shell integration (experimental)
git wt --init fish | source

# Starship prompt
starship init fish | source

# GitHub token for Claude Code github MCP plugin
if command -q gh
    set -gx GITHUB_PERSONAL_ACCESS_TOKEN (gh auth token)
end

{{- if eq .machine.type "work" }}

# Aliases
alias claude-ci 'CLAUDE_CONFIG_DIR=~/.claude-ci claude'
{{- end }}
